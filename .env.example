# ---------------------------------------------------------------------------
# Gastric IQ Social Content Studio — environment template
# Copy to .env (root, for docker-compose) and apps/web/.env (for local dev).
# Never commit real values; on dokploy these come from the project's secrets.
# ---------------------------------------------------------------------------

# Database (Postgres)
POSTGRES_USER=giq
POSTGRES_PASSWORD=giq_dev_password
POSTGRES_DB=giq_studio
DATABASE_URL=postgresql://giq:giq_dev_password@localhost:5432/giq_studio

# Redis
REDIS_URL=redis://localhost:6379

# Auth (single operator)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
OPERATOR_EMAIL=you@example.com
# Set via `pnpm --filter @giq/web create:operator` (reads OPERATOR_EMAIL + prompts/uses OPERATOR_PASSWORD)
OPERATOR_PASSWORD=

# LLM (OpenAI — operator has this key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Media generation
FAL_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_BR_MALE=
ELEVENLABS_VOICE_ID_BR_FEMALE=
ELEVENLABS_VOICE_ID_US_MALE=
ELEVENLABS_VOICE_ID_US_FEMALE=

# Publishers
BUFFER_API_KEY=
BUFFER_ORG_ID=
ZERNIO_API_KEY=
ZERNIO_BASE_URL=https://api.zernio.com

# Postiz (both brands publish here: Gastric IQ = EN, Gastric IQ Brasil = PT-BR)
# API key: Postiz → Settings → Developers → Public API.
# Base URL is the Postiz backend (public API is served at `${base}/public/v1`);
# for a single-domain self-hosted deploy the backend is proxied under /api.
POSTIZ_API_KEY=
POSTIZ_BASE_URL=https://postiz.reggiespace.ca/api
# Integration (channel) ids from GET ${POSTIZ_BASE_URL}/public/v1/integrations
POSTIZ_CHANNEL_US_FACEBOOK=
POSTIZ_CHANNEL_US_INSTAGRAM=
POSTIZ_CHANNEL_BR_FACEBOOK=
POSTIZ_CHANNEL_BR_INSTAGRAM=

# Worker (web → worker calls use WORKER_BASE_URL; worker → web callbacks use WEB_BASE_URL)
WORKER_BASE_URL=http://localhost:8000
WORKER_SHARED_SECRET=change-me-internal-worker-secret
WEB_BASE_URL=http://localhost:3000

# Storage (local volume in Phase 1)
STORAGE_DIR=./storage
PUBLIC_MEDIA_BASE_URL=http://localhost:3000/media

# --- Media hosting (Garage S3) ---
STORAGE_BACKEND=local            # local | s3
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=garage
MEDIA_S3_ENDPOINT=
MEDIA_PUBLIC_BASE_URL=           # optional CDN base; else <endpoint>/<bucket>/<key>
AWS_ACCESS_KEY_ID=               # Garage key (write to media prefixes only)
AWS_SECRET_ACCESS_KEY=

# --- Daily pipeline cron ---
CRON_SECRET=                     # shared secret for POST /api/cron/daily-run
