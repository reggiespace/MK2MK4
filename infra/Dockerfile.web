# Gastric IQ web app — Next.js standalone build
FROM node:24-slim AS base
RUN corepack enable
WORKDIR /app

# ---- deps ----
FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/package.json
RUN pnpm install --frozen-lockfile --prod=false

# ---- build ----
FROM base AS build
ENV CI=true
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
# prisma generate only needs DATABASE_URL to be present (no real connection is
# made); the real value is injected at container runtime, not build time.
ENV DATABASE_URL="postgresql://build:build@localhost:5432/build"
RUN pnpm --filter @giq/web exec prisma generate
RUN pnpm --filter @giq/web build

# ---- run ----
FROM node:24-slim AS run
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
# Runtime deps for entrypoint: migrations runner (pg) + operator init (bcryptjs) + prisma schema
COPY --from=build /app/apps/web/node_modules/bcryptjs ./apps/web/node_modules/bcryptjs
COPY --from=build /app/apps/web/prisma ./apps/web/prisma
# Install pg for run-migrations.js (pnpm symlinks don't survive multi-stage copy)
RUN npm install --prefix /migrations-deps pg@8 --save 2>/dev/null
COPY infra/init-operator.js /init-operator.js
COPY infra/run-migrations.js /run-migrations.js
COPY infra/entrypoint-web.sh /entrypoint.sh
RUN chmod +x /init-operator.js /entrypoint.sh
EXPOSE 3000
ENTRYPOINT ["/entrypoint.sh"]
